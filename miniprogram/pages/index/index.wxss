/* 首页样式 */
.page-container { min-height: 100vh; padding: 32rpx; padding-bottom: 120rpx; box-sizing: border-box; }
.hero-section { text-align: center; padding: 48rpx 0 32rpx; }
.hero-icon { font-size: 96rpx; display: block; margin-bottom: 16rpx; }
.hero-title { font-size: 52rpx; font-weight: 800; color: #4A90D9; display: block; letter-spacing: 4rpx; }
.hero-subtitle { font-size: 28rpx; color: #888; display: block; margin-top: 8rpx; }
.card-title { font-size: 32rpx; font-weight: 700; color: #333; display: block; margin-bottom: 12rpx; }
.card-desc { font-size: 26rpx; color: #888; line-height: 1.6; }
.step-badge { width: 48rpx; height: 48rpx; background: linear-gradient(135deg, #4A90D9, #357ABD); color: #FFF; border-radius: 50%; display: inline-flex; align-items: center; justify-content: center; font-size: 26rpx; font-weight: 700; margin-bottom: 12rpx; }
.step-title { font-size: 30rpx; font-weight: 700; color: #333; display: block; margin-bottom: 20rpx; }
.form-group { margin-bottom: 28rpx; }
.form-label { font-size: 26rpx; color: #666; display: block; margin-bottom: 12rpx; }
.age-selector { display: flex; flex-wrap: wrap; gap: 16rpx; }
.age-btn { padding: 16rpx 32rpx; background: #F5F7FA; border-radius: 32rpx; font-size: 26rpx; color: #666; border: 2rpx solid transparent; transition: all 0.2s; }
.age-btn.active { background: #EBF3FF; color: #4A90D9; border-color: #4A90D9; font-weight: 600; }
.partner-list { display: flex; gap: 20rpx; }
.partner-item { flex: 1; background: #F5F7FA; border-radius: 20rpx; padding: 28rpx 16rpx; text-align: center; border: 3rpx solid transparent; transition: all 0.2s; }
.partner-item.selected { background: #EBF3FF; border-color: #4A90D9; transform: scale(1.03); box-shadow: 0 4rpx 20rpx rgba(74,144,217,0.2); }
.partner-emoji { font-size: 56rpx; display: block; margin-bottom: 8rpx; }
.partner-name { font-size: 26rpx; font-weight: 600; color: #333; display: block; }
.partner-desc { font-size: 22rpx; color: #999; display: block; margin-top: 4rpx; }
.tone-list { display: flex; flex-direction: column; gap: 16rpx; }
.tone-item { display: flex; align-items: center; gap: 20rpx; padding: 20rpx 24rpx; background: #F5F7FA; border-radius: 16rpx; border: 2rpx solid transparent; transition: all 0.2s; }
.tone-item.selected { background: #EBF3FF; border-color: #4A90D9; }
.tone-emoji { font-size: 40rpx; }
.tone-info { flex: 1; }
.tone-name { font-size: 28rpx; font-weight: 600; color: #333; display: block; }
.tone-desc { font-size: 24rpx; color: #888; display: block; margin-top: 2rpx; }
.start-btn { width: 100%; margin-top: 32rpx; font-size: 34rpx !important; padding: 28rpx !important; }
.start-btn[disabled] { opacity: 0.4; box-shadow: none; }
.welcome-card { text-align: center; padding: 40rpx 32rpx; }
.welcome-emoji { font-size: 80rpx; display: block; margin-bottom: 16rpx; }
.welcome-text { font-size: 40rpx; font-weight: 700; color: #333; display: block; }
.welcome-desc { font-size: 26rpx; color: #888; display: block; margin-top: 8rpx; }
.info-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 20rpx; margin-bottom: 16rpx; }
.info-card { background: #FFFFFF; border-radius: 20rpx; padding: 28rpx 20rpx; text-align: center; box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.05); }
.info-icon { font-size: 40rpx; display: block; margin-bottom: 8rpx; }
.info-value { font-size: 28rpx; font-weight: 700; color: #333; display: block; }
.info-label { font-size: 22rpx; color: #999; display: block; margin-top: 4rpx; }
.topics-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 16rpx; }
.refresh-btn { font-size: 24rpx; color: #4A90D9; padding: 8rpx 16rpx; background: #EBF3FF; border-radius: 20rpx; }
.topic-list { display: flex; flex-direction: column; gap: 12rpx; }
.topic-item { padding: 20rpx 24rpx; background: linear-gradient(135deg, #F8FBFF, #F0F6FF); border-radius: 16rpx; border-left: 6rpx solid #4A90D9; transition: all 0.2s; }
.topic-item:active { background: #E8F0FE; transform: translateX(6rpx); }
.topic-text { font-size: 28rpx; color: #333; line-height: 1.5; }
.empty-topics { text-align: center; padding: 32rpx; color: #999; font-size: 26rpx; }
