/* 设置页面样式 */
.settings-container { min-height: 100vh; padding: 24rpx 32rpx; padding-bottom: 120rpx; box-sizing: border-box; }
.profile-card { padding: 32rpx; }
.profile-header { display: flex; align-items: center; gap: 24rpx; }
.profile-avatar { width: 96rpx; height: 96rpx; border-radius: 50%; background: linear-gradient(135deg, #4A90D9, #357ABD); color: #FFF; display: flex; align-items: center; justify-content: center; font-size: 40rpx; font-weight: 700; }
.profile-info { flex: 1; }
.profile-name { font-size: 34rpx; font-weight: 700; color: #333; display: block; }
.profile-age { font-size: 26rpx; color: #888; display: block; margin-top: 6rpx; }
.edit-btn { font-size: 26rpx; color: #4A90D9; padding: 10rpx 28rpx; background: #EBF3FF; border-radius: 24rpx; }
.section-title { font-size: 24rpx; color: #999; margin: 32rpx 0 16rpx; padding-left: 8rpx; text-transform: uppercase; letter-spacing: 2rpx; }
.setting-item { display: flex; align-items: center; justify-content: space-between; padding: 28rpx 0; }
.setting-left { display: flex; align-items: center; gap: 20rpx; flex: 1; }
.setting-icon { font-size: 36rpx; }
.setting-info { display: flex; flex-direction: column; }
.setting-label { font-size: 28rpx; color: #333; font-weight: 500; }
.setting-value { font-size: 24rpx; color: #999; margin-top: 4rpx; }
.setting-arrow { font-size: 36rpx; color: #CCC; font-weight: 300; }
.setting-divider { height: 1rpx; background: #F0F0F0; }
.difficulty-card .card-title { margin-bottom: 20rpx; }
.difficulty-list { display: flex; flex-direction: column; gap: 12rpx; }
.diff-item { display: flex; align-items: center; gap: 16rpx; padding: 16rpx 20rpx; border-radius: 12rpx; background: #F5F7FA; transition: all 0.2s; }
.diff-item.active { background: #EBF3FF; border: 2rpx solid #4A90D9; }
.diff-badge { font-size: 22rpx; font-weight: 700; color: #4A90D9; background: #EBF3FF; padding: 6rpx 16rpx; border-radius: 12rpx; white-space: nowrap; }
.diff-item.active .diff-badge { background: #4A90D9; color: #FFF; }
.diff-desc { font-size: 24rpx; color: #666; line-height: 1.5; }
.about-card { padding: 8rpx 0; }
.about-item { display: flex; justify-content: space-between; padding: 24rpx 32rpx; }
.about-label { font-size: 28rpx; color: #666; }
.about-value { font-size: 28rpx; color: #333; }
.reset-section { margin-top: 48rpx; margin-bottom: 32rpx; text-align: center; }
.reset-btn { width: 80%; border-color: #FF4757 !important; color: #FF4757 !important; font-size: 28rpx !important; }
.modal-mask { position: fixed; top: 0; left: 0; right: 0; bottom: 0; background: rgba(0,0,0,0.5); display: flex; align-items: flex-end; justify-content: center; z-index: 100; animation: fadeIn 0.2s; }
.modal-content { background: #FFF; border-radius: 32rpx 32rpx 0 0; padding: 40rpx 32rpx 32rpx; width: 100%; max-width: 750rpx; max-height: 70vh; overflow-y: auto; }
.modal-title { font-size: 34rpx; font-weight: 700; color: #333; display: block; margin-bottom: 28rpx; text-align: center; }
.modal-input { width: 100%; box-sizing: border-box; margin-bottom: 24rpx; }
.modal-actions { display: flex; gap: 20rpx; margin-top: 24rpx; }
.modal-btn { flex: 1; font-size: 28rpx !important; padding: 20rpx !important; border-radius: 40rpx !important; }
.age-picker { display: flex; flex-wrap: wrap; gap: 16rpx; justify-content: center; padding: 16rpx 0; }
.age-option { width: 120rpx; height: 72rpx; display: flex; align-items: center; justify-content: center; background: #F5F7FA; border-radius: 16rpx; font-size: 28rpx; color: #666; border: 2rpx solid transparent; transition: all 0.2s; }
.age-option.active { background: #EBF3FF; color: #4A90D9; border-color: #4A90D9; font-weight: 700; }
.partner-options { display: flex; flex-direction: column; gap: 16rpx; }
.partner-option { display: flex; align-items: center; gap: 20rpx; padding: 24rpx; background: #F5F7FA; border-radius: 16rpx; border: 2rpx solid transparent; transition: all 0.2s; }
.partner-option.selected { background: #EBF3FF; border-color: #4A90D9; }
.partner-option-emoji { font-size: 48rpx; }
.partner-option-info { flex: 1; }
.partner-option-name { font-size: 28rpx; font-weight: 600; color: #333; display: block; }
.partner-option-desc { font-size: 24rpx; color: #888; display: block; margin-top: 4rpx; }
.partner-check { font-size: 32rpx; color: #4A90D9; font-weight: 700; }
.tone-options { display: flex; flex-direction: column; gap: 16rpx; }
.tone-option { display: flex; align-items: center; gap: 20rpx; padding: 24rpx; background: #F5F7FA; border-radius: 16rpx; border: 2rpx solid transparent; transition: all 0.2s; }
.tone-option.selected { background: #EBF3FF; border-color: #4A90D9; }
.tone-option-emoji { font-size: 40rpx; }
.tone-option-info { flex: 1; }
.tone-option-name { font-size: 28rpx; font-weight: 600; color: #333; display: block; }
.tone-option-desc { font-size: 24rpx; color: #888; display: block; margin-top: 4rpx; }
