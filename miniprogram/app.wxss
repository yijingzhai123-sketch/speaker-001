page {
  background-color: #F5F7FA;
  font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, "Helvetica Neue", Arial, sans-serif;
  color: #333333;
  font-size: 28rpx;
  line-height: 1.6;
}

.btn-primary {
  background: linear-gradient(135deg, #4A90D9 0%, #357ABD 100%);
  color: #FFFFFF;
  border-radius: 48rpx;
  font-size: 32rpx;
  font-weight: 600;
  padding: 24rpx 48rpx;
  border: none;
  box-shadow: 0 4rpx 16rpx rgba(74, 144, 217, 0.3);
  transition: all 0.25s ease;
}

.btn-primary:active {
  opacity: 0.85;
  transform: scale(0.97);
  box-shadow: 0 2rpx 8rpx rgba(74, 144, 217, 0.2);
}

.btn-secondary {
  background: #FFFFFF;
  color: #4A90D9;
  border: 2rpx solid #4A90D9;
  border-radius: 48rpx;
  font-size: 28rpx;
  padding: 20rpx 40rpx;
}

.btn-secondary:active {
  background: #F0F6FF;
}

.card {
  background: #FFFFFF;
  border-radius: 24rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 16rpx rgba(0, 0, 0, 0.06);
}

.input-field {
  background: #F5F7FA;
  border-radius: 16rpx;
  padding: 20rpx 28rpx;
  font-size: 28rpx;
  border: 2rpx solid transparent;
  transition: border-color 0.2s;
}

.input-field:focus {
  border-color: #4A90D9;
  background: #FFFFFF;
}

.safe-bottom {
  padding-bottom: constant(safe-area-inset-bottom);
  padding-bottom: env(safe-area-inset-bottom);
}

@keyframes fadeIn {
  from { opacity: 0; transform: translateY(20rpx); }
  to { opacity: 1; transform: translateY(0); }
}

.fade-in {
  animation: fadeIn 0.35s ease-out;
}

.loading-dots {
  display: inline-flex;
  gap: 8rpx;
  align-items: center;
}

.loading-dots view {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  background: #4A90D9;
  animation: bounce 1.4s ease-in-out infinite;
}

.loading-dots view:nth-child(2) { animation-delay: 0.2s; }
.loading-dots view:nth-child(3) { animation-delay: 0.4s; }

@keyframes bounce {
  0%, 80%, 100% { transform: scale(0.6); opacity: 0.4; }
  40% { transform: scale(1); opacity: 1; }
}
